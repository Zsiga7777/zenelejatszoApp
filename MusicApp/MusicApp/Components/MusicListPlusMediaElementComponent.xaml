<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:components="clr-namespace:MusicApp.Components"
             xmlns:models="clr-namespace:MusicApp.Core.Models;assembly=MusicApp.Core"
             x:Class="MusicApp.Components.MusicListPlusMediaElementComponent"
             Loaded="LoadedEvent"
             Unloaded="UnloadedEvent"
             x:Name="this">
    
    <ContentView.Resources>
        <toolkit:ItemTappedEventArgsConverter x:Key="ItemTappedEventArgsConverter"/>
    </ContentView.Resources>

    <Grid HorizontalOptions="Center">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="193"/>
        </Grid.RowDefinitions>
        <CollectionView ItemsSource="{Binding Musics, Source={x:Reference this}}" Grid.Row="0"
                 VerticalScrollBarVisibility="Never"
                        SelectionMode="Single"
                        SelectionChangedCommand="{Binding OnMusicTappedCommand, Source={x:Reference this}}"
                  MaximumWidthRequest="600"
                        SelectedItem="{Binding SelectedMusic ,Source={x:Reference this}}">
            
            <CollectionView.ItemTemplate  >
                <DataTemplate x:DataType="models:MusicModel" >
                    <StackLayout>
                    <VisualStateManager.VisualStateGroups>
                        <VisualStateGroup Name="CommonStates">
                            <VisualState Name="Normal"></VisualState>
                            <VisualState Name="Selected">
                                <VisualState.Setters>
                                        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=#f5f7f6, Dark=#2d2e2d}"></Setter>
                                    </VisualState.Setters>
                            </VisualState>

                        </VisualStateGroup>
                    </VisualStateManager.VisualStateGroups>
                    <components:MusicListItemComponent Music="{Binding .}"
                                                   AddToQueueCommand="{Binding OnMusicAddToQueueCommand, Source={x:Reference this}}"
                                                   CommandParameter="{Binding Path, Source={x:Reference this}}" />
                    </StackLayout>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <components:MediaElementComponent SelectedMusic="{Binding SelectedMusic, Source={x:Reference this}}"
                                       IsMediaPlayerVisible="{Binding IsMediaPlayerVisible, Source={x:Reference this}}"
                                      OnMusicEndedCommand="{Binding OnMusicEndedCommand, Source={x:Reference this}}"
                                       OnPreviousTrackTappedCommand="{Binding OnPreviousTrackTappedCommand, Source={x:Reference this}}"
                                      OnNextTrackTappedCommand="{Binding OnNextTrackTappedCommand ,Source={x:Reference this}}"
                                          PlayButtonVisible="{Binding PlayButtonVisible, Source={x:Reference this}}"
                                          PauseButtonVisible="{Binding PauseButtonVisible, Source={x:Reference this}}"
                                      Grid.Row="1" Margin="0, 3, 0, 10"/>
    </Grid>

</ContentView>
