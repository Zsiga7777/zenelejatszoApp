<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MusicApp.Components.FolderListItemComponent"
             xmlns:components="clr-namespace:MusicApp.Components"
    xmlns:models="clr-namespace:MusicApp.Core.Models;assembly=MusicApp.Core"
    x:DataType="components:FolderListItemComponent"
    x:Name="this">
    <StackLayout>
        
        <Border MaximumWidthRequest="220" Style="{StaticResource BorderStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="100"/>
                </Grid.ColumnDefinitions>
                <Label Text="{Binding Folder.FolderName, Source={x:Reference this}}" Grid.Column="0"
                       HorizontalTextAlignment="Center"
                       VerticalTextAlignment="Center"/>
            <ImageButton Source="{AppThemeBinding Dark=deletesymbol_dark.png, Light=deletesymbol_light.png}" BackgroundColor="Transparent"
        CommandParameter="{Binding Folder.FolderName ,Source={x:Reference this}}"
Command="{Binding DeleteFolderFromListCommad,Source={x:Reference this}}"
HorizontalOptions="Center"
VerticalOptions="Center"
Grid.Column="1"/>
            </Grid>
        </Border>
    </StackLayout>
</ContentView>
