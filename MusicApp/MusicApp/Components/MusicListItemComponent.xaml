<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MusicApp.Components.MusicListItemComponent"
             xmlns:components="clr-namespace:MusicApp.Components"
xmlns:models="clr-namespace:MusicApp.Core.Models;assembly=MusicApp.Core"
x:DataType="components:MusicListItemComponent"
x:Name="this">
    <StackLayout HeightRequest="55" Margin="0,0,0,2">
        <Border Style="{StaticResource BorderStyle}" MaximumWidthRequest="600" >
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="45"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="50"/>
                </Grid.ColumnDefinitions>
                <Label Text="{Binding Music.Title,Source={x:Reference this}}" LineBreakMode="TailTruncation" VerticalOptions="Center"  Grid.Row="0" Grid.Column="0"/>
                <ImageButton Source="{AppThemeBinding Dark=addsymbol_dark.png, Light=addsymbol_light.png}" Grid.Row="0" Grid.Column="1" BackgroundColor="Transparent" 
                         Command="{Binding AddToQueueCommand,Source={x:Reference this} }"
                         CommandParameter="{Binding Music.Path,Source={x:Reference this}}"/>
            </Grid>
        </Border>
    </StackLayout>
</ContentView>
